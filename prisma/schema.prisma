generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("member")
  createdAt    DateTime @default(now())

  recipes             Recipe[]
  mealPlanItems       MealPlanItem[]
  pantryItems         PantryItem[]
  shoppingListCaches  ShoppingListCache[]
  customShoppingItems CustomShoppingItem[]
}

model Recipe {
  id          String   @id @default(cuid())
  title       String
  description String?
  sourceUrl   String?
  imageUrl    String?
  servings    Int      @default(4)
  prepTime    Int?
  cookTime    Int?
  cuisine     String?
  mealType    String?
  tags        String[]
  isFavorite  Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  ingredients   Ingredient[]
  steps         Step[]
  mealPlanItems MealPlanItem[]
  sharedRecipes SharedRecipe[]

  @@index([userId])
}

model Ingredient {
  id        String  @id @default(cuid())
  name      String
  quantity  Float?
  unit      String?
  group     String?
  toTaste   Boolean @default(false)
  sortOrder Int     @default(0)
  recipeId  String
  recipe    Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model Step {
  id        String @id @default(cuid())
  text      String
  sortOrder Int    @default(0)
  recipeId  String
  recipe    Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model MealPlanItem {
  id       String   @id @default(cuid())
  date     DateTime
  mealType String
  recipeId String
  userId   String
  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PantryItem {
  id     String @id @default(cuid())
  name   String
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model ShoppingListCache {
  id           String   @id @default(cuid())
  weekStart    DateTime
  mealPlanHash String
  items        Json
  createdAt    DateTime @default(now())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
}

model CustomShoppingItem {
  id        String   @id @default(cuid())
  weekStart DateTime
  name      String
  checked   Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart, name])
}

model SharedRecipe {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  recipeId  String
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  createdBy String
  createdAt DateTime @default(now())
}
